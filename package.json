{
    "name": "gpamn",
    "private": true,
    "packageManager": "pnpm@10.6.5",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "build": "turbo run build",
        "dev": "docker compose up -d && portless alias gpa-web 80 && portless alias gpa-admin 6100 && portless alias gpa-mail 8045 && portless alias gpa-data 6200",
        "dev:stop": "docker compose down",
        "dev:logs": "docker compose logs -f",
        "lint": "turbo run lint",
        "test": "turbo run test",
        "test:watch": "turbo run test:watch",
        "typecheck": "turbo run typecheck",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json,css}\"",
        "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,md,json,css}\"",
        "db:generate": "turbo run db:generate --filter=@repo/database",
        "db:migrate": "turbo run db:migrate --filter=@repo/database",
        "db:push": "turbo run db:push --filter=@repo/database",
        "db:studio": "turbo run db:studio --filter=@repo/database",
        "e2e": "turbo run e2e --filter=@repo/e2e",
        "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s",
        "prepare": "husky"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@tailwindcss/node": "^4.2.1",
        "conventional-changelog-cli": "^5.0.0",
        "eslint-plugin-tailwind-canonical-classes": "^1.3.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "turbo": "^2.4.4"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "sharp"
        ]
    }
}
